FROM node:20-alpine

WORKDIR /app

# 1. Сначала копируем только манифесты зависимостей.
# Этот слой кэшируется и пересобирается только если изменились package*.json
COPY package.json package-lock.json ./

# 2. Устанавливаем зависимости через npm ci для воспроизводимой установки
RUN npm ci

# 3. Копируем исходный код — после установки зависимостей,
# чтобы изменения в src не инвалидировали кэш node_modules
COPY . .

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "--port", "5173"]
